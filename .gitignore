data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
*.log
*.csv
*.json
*.parquet

# --- Jupyter Notebooks ---
.ipynb_checkpoints

# --- Terraform ---
.terraform/
*.tfstate
*.tfstate.backup